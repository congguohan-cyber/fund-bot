# 飞书应用配置
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=

# 飞书消息配置
# 接收分析的飞书用户 open_id（你的飞书ID）
FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxx
# Bot 所在的群聊 chat_id（如果推送到群，可选）
FEISHU_CHAT_ID=

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# 模型选择: claude-sonnet-5-20251001 或 claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-5-20251001

# 数据库路径
DATABASE_PATH=./data/fund_bot.db

# 调试模式
DEBUG=false
